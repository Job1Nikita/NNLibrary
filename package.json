{
  "name": "library-archive-portal",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready MVP archive portal with retro directory listing UX",
  "main": "dist/src/server.js",
  "scripts": {
    "dev:web": "tsx watch src/server.ts",
    "dev:bot": "tsx watch src/bot/index.ts",
    "build": "tsc -p tsconfig.json",
    "start:web": "node dist/src/server.js",
    "start:bot": "node dist/src/bot/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "seed:admin": "tsx scripts/seed-admin.ts",
    "register:file": "tsx scripts/register-file.ts",
    "scan:storage": "tsx scripts/scan-storage.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.5.0",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "multer": "^2.0.0",
    "morgan": "^1.10.0",
    "telegraf": "^4.16.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.1",
    "@types/multer": "^1.4.12",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.13.14",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}


