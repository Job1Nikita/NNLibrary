<%- include("partials/head", { title }) %>

<main class="auth-shell">
  <section class="auth-card">
    <h1><%= t("auth.registerTitle") %></h1>
    <p class="muted"><%= t("auth.registerLead") %></p>

    <% if (flash) { %>
      <div class="flash <%= flash.type %>"><%= flash.message %></div>
    <% } %>

    <form method="post" action="/register" class="stack-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>
        <%= t("auth.login") %>
        <input type="text" name="login" minlength="3" maxlength="32" pattern="[a-zA-Z0-9_.-]+" required autocomplete="username" />
      </label>
      <label>
        <%= t("auth.password") %>
        <input type="password" name="password" minlength="8" maxlength="128" required autocomplete="new-password" />
      </label>

      <%- include("partials/captcha") %>

      <button type="submit" class="btn"><%= t("auth.registerSubmit") %></button>
    </form>

    <p class="muted"><%= t("auth.hasAccount") %> <a href="/login"><%= t("auth.goLogin") %></a></p>
  </section>
</main>

<script src="/public/js/captcha.js" defer></script>
<%- include("partials/foot") %>
